---
import Base from '../layouts/Base.astro';
---

<Base title="Home">
  <section>
    <h1>Hi</h1>
    <p>
      My name is Josh. I'm a full stack (front-end leaning) software engineer. I've shipped software that I can confidently say you've crossed paths with in one way or another. This site is where I post about projects, releases, and whatever else is on my mind.
    </p>
    <div class="links">
      <a href="https://github.com/deckmasterbeam" target="_blank" rel="noopener noreferrer">GitHub</a>
      <a href="https://www.linkedin.com/in/josh-j-barnett/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      <a href="https://instagram.com/__josh_barnett" target="_blank" rel="noopener noreferrer">Instagram</a>
    </div>
  </section>
</Base>

<style>
  section {
    padding-top: 2rem;
  }

  h1 {
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }

  p {
    color: var(--color-muted);
  }

  a {
    color: var(--color-text);
  }

  .links {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .links a {
    font-size: 0.9rem;
    color: var(--color-muted);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--color-text);
  }
</style>
