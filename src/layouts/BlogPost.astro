---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  description: string;
  tags: string[];
}

const { title, date, description, tags } = Astro.props;
const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={title} description={description}>
  <article>
    <header>
      <time datetime={date.toISOString()}>{formatted}</time>
      <h1>{title}</h1>
      {tags.length > 0 && (
        <div class="tags">
          {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      )}
    </header>
    <div class="content">
      <slot />
    </div>
  </article>
</Base>

<style>
  article {
    padding-top: 1rem;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  time {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  h1 {
    margin: 0.5rem 0 1rem;
    font-size: 1.75rem;
    line-height: 1.3;
  }

  .tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.8rem;
    color: var(--color-muted);
    background: #f3f4f6;
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .content :global(h2) {
    margin-top: 2rem;
    font-size: 1.25rem;
  }

  .content :global(h3) {
    margin-top: 1.5rem;
    font-size: 1.05rem;
  }

  .content :global(p) {
    margin: 1rem 0;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
  }
</style>
