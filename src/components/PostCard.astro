---
import type { Post } from '../types/post';

type Props = Post & { variant?: 'list' | 'card' | 'card-sm' };

const props = Astro.props;
const { title, date, description, slug, variant = 'list' } = props;
const formatted = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const href = props.type === 'project'
  ? `/projects/${slug}`
  : props.type === 'release'
  ? `/releases/${slug}`
  : `/blog/${slug}`;
---

<article class={variant}>
  <time datetime={date.toISOString()}>{formatted}</time>
  <h2><a href={href}>{title}</a></h2>
  <p>{description}</p>
</article>

<style>
  article.list {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  article.card {
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }

  article.card-sm {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }

  article.card-sm p,
  article.card-sm .repo-link {
    display: none;
  }

  article.card-sm h2 {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 500;
  }

  article.card-sm time {
    flex-shrink: 0;
  }

  time {
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  h2 {
    margin: 0.25rem 0 0.5rem;
    font-size: 1.1rem;
    font-weight: 600;
  }

  h2 a {
    text-decoration: none;
  }

  h2 a:hover {
    opacity: 0.7;
  }

  p {
    margin: 0 0 0.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

</style>
